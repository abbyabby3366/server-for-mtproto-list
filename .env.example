# Server Configuration
PORT=3000
NODE_ENV=development

# Optional: API key for securing the proxy list endpoint
# If set, clients must send this as Bearer token in Authorization header
API_KEY=

# Proxy list - JSON array of MTProto proxies
# Each proxy: { "host": "IP", "port": 443, "secret": "hex_secret" }
# You can also edit proxies.json directly
